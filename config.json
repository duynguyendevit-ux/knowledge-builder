{
  "llm": {
    "provider": "openrouter",
    "model": "qwen/qwen3.6-plus:free",
    "apiKey": "",
    "baseUrl": "https://openrouter.ai/api/v1"
  },
  "paths": {
    "raw": "./raw",
    "wiki": "./wiki"
  },
  "processing": {
    "autoSummarize": true,
    "extractConcepts": true,
    "findConnections": true,
    "batchSize": 10
  },
  "obsidian": {
    "frontmatter": true,
    "tags": true,
    "backlinks": true
  },
  "healthCheck": {
    "checkInconsistencies": true,
    "suggestMissing": true,
    "findConnections": true
  }
}
